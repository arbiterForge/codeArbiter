# v1 legacy framework tree (the pre-rewrite .agents/ source + shims). Kept on
# disk for reference; never part of the v2 plugin.
legacy/

# Local environment files.
.env
.env.local

# Local Claude Code project settings — machine-specific (statusline/hook paths),
# never shared. Each developer's own .claude/settings.json wires the plugin hooks.
.claude/settings.json

# Local Claude Code overrides (may carry machine-local secrets like FARM_API_KEY
# injected via `env`). Repo-tracked guardrail so the exclusion travels with the
# repo instead of relying on each developer's global gitignore.
.claude/settings.local.json

# Codex CLI local project config — same guardrail as settings.local.json: can
# carry machine-local secrets (shell_environment_policy.set). Repo-shippable
# .codex/ content (agents/, skills/) is NOT ignored.
.codex/config.toml

# Transient ADR-authoring marker under the root-level state dir (set by /ca:adr).
# Not project state.
.codearbiter/.markers/

# Decompose draft directory — per-layer compaction-resilience drafts written by
# the `decompose` skill. Auto-deleted when the interview completes; resumable
# via /ca:decompose if a session is interrupted. Never committed.
.codearbiter/.decompose-draft/

# Transient sprint lock written by /ca:sprint (holds the active sprint slug).
# Removed when the sprint completes. Local-only, never committed.
.codearbiter/sprint-active

# OS-owned sidecar lock file for the task-board writer (#271 C-2/C-3):
# taskwrite.py takes a cross-process file lock on open-tasks.md.lock while it
# reads/mutates/writes the board. It is not project state and is never committed.
.codearbiter/open-tasks.md.lock

# Python bytecode (e.g. the statusline dev harnesses under plugins/ca/hooks/).
__pycache__/

# Ephemeral execution scaffolding written by long plan runs. Removed in the
# plan's cleanup phase. Never committed.
/.plan-tasks/

# Node dependencies — never committed. Root-level appears from ad-hoc tooling;
# farm.ts dev deps live under plugins/ca/tools and are only needed to build farm.js.
/node_modules/
plugins/ca/tools/node_modules/
plugins/ca-pi/tools/node_modules/

# Docs site (Astro Starlight) — local deps, build output, and Astro cache.
site/node_modules/
site/dist/
site/.astro/
site/*.log

# Generated reference output — regenerated deterministically by `npm run gen`
# (wired into predev/prebuild), so it is not committed. The generator + its tests
# are the reviewable source of truth; the hand-written narrative pages directly
# under site/src/content/docs/ ARE committed.
site/src/content/docs/reference/
site/src/generated/

# On-site changelog — regenerated from the repo-root CHANGELOG.md by `npm run gen`
# (render-changelog.ts). Same never-committed discipline as reference/ above.
site/src/content/docs/changelog.md

# Farm dispatcher runtime artifacts — worktrees, reports, integration branch staging.
# Written per-run in any project using codeArbiter. Never committed to the plugin repo.
.farm/

# Root-level scratch directory — local experiments, never committed.
/tmp/
plugins/ca-sandbox/tools/node_modules/
plugins/ca-sandbox/tools/**/.nixpacks/
plugins/ca-sandbox/tools/**/.ca-sandbox.nixpacks.Dockerfile
