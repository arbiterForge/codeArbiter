# v1 legacy framework tree (the pre-rewrite .agents/ source + shims). Kept on
# disk for reference; never part of the v2 plugin.
legacy/

# Local environment files.
.env
.env.local

# Transient ADR-authoring marker under the root-level state dir (set by /ca:adr).
# Not project state.
.codearbiter/.markers/

# Decompose draft directory — per-layer compaction-resilience drafts written by
# the `decompose` skill. Auto-deleted when the interview completes; resumable
# via /ca:decompose if a session is interrupted. Never committed.
.codearbiter/.decompose-draft/

# Python bytecode (e.g. the statusline dev harnesses under plugins/ca/hooks/).
__pycache__/

# Ephemeral execution scaffolding written by long plan runs. Removed in the
# plan's cleanup phase. Never committed.
/.plan-tasks/
