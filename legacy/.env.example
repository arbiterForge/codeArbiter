
AWS_REGION=us-east-1
AWS_PROFILE=default
LOG_LEVEL=INFO

# Add solution-specific variables below:
# MY_VAR=your-value-here

# .env.example — Environment variable template for COVE solution repos
# =====================================================================
#
# HOW TO USE:
#   1. Copy this file to .env:       cp .env.example .env
#   2. Fill in the real values in .env (NEVER commit .env to Git)
#   3. Your application loads .env at runtime (python-dotenv, direnv, etc.)
#
# IMPORTANT:
#   - .env is listed in .gitignore — it will NOT be committed.
#   - All values below are PLACEHOLDERS. They are not real credentials.
#   - For production/lab environments, use AWS Secrets Manager instead
#     of .env files. See SECURITY.md for the secrets policy.
#
# =====================================================================

# --- AWS Configuration ---
# Used by boto3, AWS CLI, and Terraform.
# Prefer IAM roles on EC2 over static keys. If you must use keys,
# rotate them every 90 days.
AWS_ACCESS_KEY_ID=your-aws-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key-here
AWS_DEFAULT_REGION=us-east-1

# --- Gitea ---
# Personal access token for Gitea API calls (releases, webhooks, etc.).
# Generate at: Gitea → User Settings → Applications → Generate Token
GITEA_URL=https://gitea.cove.gdit
GITEA_TOKEN=your-gitea-personal-access-token-here

# --- Database ---
# Connection string if this solution uses a database.
# Format: dialect://user:password@host:port/dbname
DATABASE_URL=postgresql://cove_user:your-db-password-here@localhost:5432/cove_db

# --- Application-Specific ---
# Add your solution's environment variables below.
# Follow the naming pattern: UPPER_SNAKE_CASE
# Include a comment for each one explaining what it does.
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Feature flags (true/false)
ENABLE_DRY_RUN=true

# API key for an external service this solution integrates with
EXTERNAL_API_KEY=your-external-api-key-here
