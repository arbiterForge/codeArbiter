{
  "name": "@cove/fusion-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "fastify": "5.8.5",
    "@fastify/cors": "10.0.1",
    "@fastify/sensible": "6.0.2",
    "drizzle-orm": "0.45.2",
    "postgres": "3.4.4",
    "zod": "3.23.8",
    "jose": "5.9.6",
    "fastify-plugin": "5.0.1"
  },
  "devDependencies": {
    "@types/node": "22.15.0",
    "@vitest/coverage-v8": "4.1.5",
    "drizzle-kit": "0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "9.1.0",
    "globals": "15.12.0",
    "prettier": "3.4.2",
    "tsx": "4.19.1",
    "typescript": "5.6.3",
    "typescript-eslint": "8.15.0",
    "vitest": "4.1.5"
  }
}
