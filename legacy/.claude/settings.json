{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make *)",
      "Bash(git *)",
      "Bash(cat .fusion/stage)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(npx vitest *)",
      "Bash(npx eslint *)",
      "Bash(npx tsc *)",
      "Bash(npm run *)",
      "Bash(npm ls *)",
      "Bash(npm audit *)",
      "Bash(eslint *)",
      "Bash(prettier --check *)",
      "Bash(yamllint *)",
      "Bash(gitleaks *)",
      "Bash(syft *)",
      "Bash(trivy *)",
      "Bash(semgrep *)",
      "Bash(osv-scanner *)",
      "Bash(openssl list -providers)",
      "Bash(node -e *)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git rebase *)",
      "Bash(git push --force *)",
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(aws * delete-*)",
      "Bash(aws * put-*)",
      "Bash(aws s3 rm *)",
      "Bash(aws iam *)",
      "Bash(aws kms *)",
      "Bash(kubectl delete *)",
      "Bash(kubectl apply *)",
      "Bash(helm uninstall *)",
      "Bash(helm install *)",
      "Bash(helm upgrade *)",
      "Bash(tofu apply *)",
      "Bash(tofu destroy *)",
      "Bash(docker push *)",
      "Bash(cosign sign *)",
      "Bash(gh pr merge *)",
      "Bash(gh release create *)",
      "Read(.env*)",
      "Read(**/id_rsa*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Edit(.gitea/workflows/**)",
      "Edit(CODEOWNERS)",
      "Edit(.fusion/stage)",
      "Edit(backend/drizzle/migrations/**)",
      "Write(.env*)"
    ]
  },
  "env": {
    "FUSION_AGENT_MODE": "1"
  }
}
