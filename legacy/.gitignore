# .gitignore — multi-language; delete sections that don't apply to this repo.

# --- Secrets and environment -------------------------------------------------
.env
.env.*
!.env.example
!.env.template
*.pem
*.key
*.p12
*.pfx
*_rsa
*_ed25519
*.secret

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg
*.egg-info/
dist/
build/
.venv/
venv/
.mypy_cache/
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.ruff_cache/

# --- Node.js -----------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-error.log*
.npm/
**/coverage/

# --- OpenTofu / Terraform ----------------------------------------------------
.terraform/
# .terraform.lock.hcl is intentionally NOT ignored — commit it to pin provider versions.
*.tfstate
*.tfstate.backup
crash.log

# --- Ansible -----------------------------------------------------------------
*.retry
# Do NOT gitignore vault-encrypted files (*.vault) — those are safe to commit.

# --- Kubernetes / K3s --------------------------------------------------------
# K3s writes kubeconfig to /etc/rancher/k3s/k3s.yaml; developers sometimes copy
# it locally. Never commit credentials.
kubeconfig
*.kubeconfig
.kube/

# --- Scan & CI artifacts -----------------------------------------------------
# SARIF files are generated by Semgrep, Bandit, and other SAST tools — upload to
# the code-scanning sink, do not commit.
*.sarif
*.log

# --- OS / editor artifacts ---------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace
*.orig

# --- Ansible runtime files ---------------------------------------------------
# inventory/hosts contains environment-specific IPs and usernames — never commit.
# hosts.example is the committed template; hosts is the local override.
inventory/hosts
*.retry

# --- Build / release artifacts -----------------------------------------------
# dist/ is committed empty (.gitkeep) so CI can populate it.
# Individual artifacts are excluded so they don't accumulate locally.
dist/*
!dist/.gitkeep
