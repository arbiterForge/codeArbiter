{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.py\"" },
          { "type": "command", "command": "python -c \"\" || python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.py\"" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash.py\"" },
          { "type": "command", "command": "python -c \"\" || python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash.py\"" }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-write.py\"" },
          { "type": "command", "command": "python -c \"\" || python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-write.py\"" }
        ]
      },
      {
        "matcher": "Edit|MultiEdit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-edit.py\"" },
          { "type": "command", "command": "python -c \"\" || python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-edit.py\"" }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-read.py\"" },
          { "type": "command", "command": "python -c \"\" || python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-read.py\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/post-write-edit.py\"" },
          { "type": "command", "command": "python -c \"\" || python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/post-write-edit.py\"" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/prune-transcript.py\"" },
          { "type": "command", "command": "python -c \"\" || python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/prune-transcript.py\"" }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/prune-transcript.py\"" },
          { "type": "command", "command": "python -c \"\" || python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/prune-transcript.py\"" }
        ]
      }
    ]
  }
}
