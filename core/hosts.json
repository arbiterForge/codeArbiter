      "surface": {
        "rules": [
          {"source_prefix": "commands/", "output_pattern": "skills/ca-{name}/SKILL.md", "exclude": ["commands/prune.md", "commands/statusline.md"], "add_skill_frontmatter": true},
          {"source_prefix": "skills/", "output_pattern": "routines/{relative}", "exclude": []},
          {"source_prefix": "includes/", "output_pattern": "includes/{relative}", "exclude": ["includes/pi-host-notes.md"]},
          {"source_prefix": "COMMANDS.md", "output_pattern": "COMMANDS.md", "exclude": []},
          {"source_prefix": "SPRINT.md", "output_pattern": "SPRINT.md", "exclude": []},
          {"source_prefix": "ORCHESTRATOR.md", "output_pattern": "ORCHESTRATOR.md", "exclude": []},
          {"source_prefix": "README.md", "output_pattern": "README.md", "exclude": ["README.md"]}
        ],
        "managed_subtrees": ["skills", "routines", "includes", "COMMANDS.md", "SPRINT.md", "ORCHESTRATOR.md"],
        "catalog": "skills/INDEX.md"
      },
      "tool_classes": {
        "Bash": "EXEC",
        "shell_command": "EXEC",
        "exec_command": "EXEC",
        "unified_exec": "EXEC",
        "apply_patch": "WRITE",
        "Write": "WRITE",
        "Edit": "WRITE",
        "Read": "READ"
      },
      "package": null
    },
    {
