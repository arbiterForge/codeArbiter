{
  "hosts": [
    {
      "name": "claude",
      "plugin_dir": "plugins/ca",
      "hooks_dir": "plugins/ca/hooks",
      "command_form": "/ca:{name}",
      "tokens": {
        "PLUGIN_ROOT": "${CLAUDE_PLUGIN_ROOT}",
        "PROJECT_DIR": "${CLAUDE_PROJECT_DIR}"
      },
      "capabilities": {
        "agents": true,
        "prune": true,
        "read_tool": true,
        "statusline": true
      },
      "surface": {
        "rules": [
          {"source_prefix": "commands/", "output_pattern": "commands/{relative}", "exclude": []},
          {"source_prefix": "skills/", "output_pattern": "skills/{relative}", "exclude": []},
          {"source_prefix": "includes/", "output_pattern": "includes/{relative}", "exclude": ["includes/codex-host-notes.md", "includes/pi-host-notes.md"]},
          {"source_prefix": "agents/", "output_pattern": "agents/{relative}", "exclude": []},
          {"source_prefix": "COMMANDS.md", "output_pattern": "COMMANDS.md", "exclude": []},
          {"source_prefix": "SPRINT.md", "output_pattern": "SPRINT.md", "exclude": []},
          {"source_prefix": "ORCHESTRATOR.md", "output_pattern": "ORCHESTRATOR.md", "exclude": []},
          {"source_prefix": "README.md", "output_pattern": "README.md", "exclude": ["README.md"]}
        ],
        "managed_subtrees": ["commands", "skills", "includes", "agents", "COMMANDS.md", "SPRINT.md", "ORCHESTRATOR.md"],
        "catalog": null
      },
      "tool_classes": {
        "Bash": "EXEC",
        "PowerShell": "EXEC",
        "Write": "WRITE",
        "Edit": "EDIT",
        "MultiEdit": "EDIT",
        "NotebookEdit": "EDIT",
        "Read": "READ"
      },
      "package": null
    },
    {
      "name": "codex",
      "plugin_dir": "plugins/ca-codex",
      "hooks_dir": "plugins/ca-codex/hooks",
      "command_form": "$ca-{name}",
      "tokens": {
        "PLUGIN_ROOT": "${CLAUDE_PLUGIN_ROOT}",
        "PROJECT_DIR": "<project-root>"
      },
      "capabilities": {
        "agents": false,
        "prune": false,
        "read_tool": false,
        "statusline": false
