# Hooks and the statusline run under bash/python on every platform — keep LF so
# they never ship with CRLF (which breaks bash shebangs and is noisy in Python).
*.sh   text eol=lf
*.py   text eol=lf
hooks/* text eol=lf

# The generated root Pi manifest is compared byte-for-byte on every host.
/package.json text eol=lf

# The markdown surface is generated (core/surface/ -> plugin trees) and verified
# by a BINARY byte-compare (tools/build-surface.py --check), so these trees must
# check out LF or the gate false-fails on Windows. Deliberately scoped: operator
# state under .codearbiter/ (audit artifacts, reports, logs) and site test
# fixtures keep their committed bytes untouched.
core/surface/** text eol=lf
plugins/**/*.md text eol=lf
docs/**/*.md    text eol=lf
/*.md           text eol=lf
