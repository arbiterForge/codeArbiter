---
/**
 * Recursive "On this page" list, mirroring Starlight's internal
 * TableOfContentsList markup so the layout matches the stock TOC. The active
 * link is driven by aria-current, set by the ca-toc scroll-spy in the
 * TableOfContents override (which fixes the last-item-at-bottom case that the
 * stock IntersectionObserver scroll-spy misses).
 */
interface TocItem {
  depth: number;
  slug: string;
  text: string;
  children: TocItem[];
}

interface Props {
  toc: TocItem[];
  depth?: number;
}

const { toc, depth = 0 } = Astro.props;
---

<ul>
  {
    toc.map((heading) => (
      <li>
        <a href={"#" + heading.slug}>
          <span>{heading.text}</span>
        </a>
        {heading.children.length > 0 && <Astro.self toc={heading.children} depth={depth + 1} />}
      </li>
    ))
  }
</ul>

<style define:vars={{ depth }}>
  ul {
    padding: 0;
    list-style: none;
  }
  a {
    --pad-inline: 0.5rem;
    display: block;
    border-radius: 0.25rem;
    padding-block: 0.25rem;
    padding-inline: calc(1rem * var(--depth) + var(--pad-inline)) var(--pad-inline);
    line-height: 1.25;
  }
  a[aria-current="true"] {
    color: var(--sl-color-text-accent);
  }
</style>
